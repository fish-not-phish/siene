# Public hostname — used for CORS, CSRF, allowed hosts, and Traefik/Nginx routing rules.
# e.g. siene.example.com  (no scheme, no trailing slash)
DOMAIN=localhost

# The externally-reachable URL of the Django backend — used by the Docker
# registry to issue token auth redirects to Docker clients, and baked into
# the Next.js bundle for browser API calls.
# Change this to your domain or LAN IP when deploying.
REGISTRY_EXTERNAL_URL=http://localhost:8000

DJANGO_SECRET_KEY=changeme-secret-key

DB_NAME=siene
DB_USER=siene
DB_PASSWORD=siene

REGISTRY_INTERNAL_TOKEN=changeme-internal-token
REGISTRY_HTTP_SECRET=changeme-registry-secret

# Email — set EMAIL_ENABLED=1 and fill in SMTP vars to send real emails.
# Leave as 0 (default) to silently discard all outgoing email.
EMAIL_ENABLED=0
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=1
# DEFAULT_FROM_EMAIL=Siene <noreply@example.com>
# EMAIL_HOST_USER=you@gmail.com
# EMAIL_HOST_PASSWORD=your-app-password

REGISTRY_TOKEN_ISSUER=siene
REGISTRY_TOKEN_SERVICE=registry.local

# ── Storage backend ───────────────────────────────────────────────────────────
# 'filesystem' (default) — images stored on the local Docker volume.
# 's3'                   — images stored in an S3-compatible bucket.
# Set via setup.sh or manually below.
REGISTRY_STORAGE_BACKEND=filesystem

# S3 / S3-compatible storage — only used when REGISTRY_STORAGE_BACKEND=s3.
# For AWS S3: leave REGISTRY_S3_ENDPOINT blank.
# For MinIO / Cloudflare R2 / other: set REGISTRY_S3_ENDPOINT to the base URL.
# REGISTRY_S3_BUCKET=my-siene-registry
# REGISTRY_S3_REGION=us-east-1
# REGISTRY_S3_ACCESS_KEY=AKIAIOSFODNN7EXAMPLE
# REGISTRY_S3_SECRET_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
# REGISTRY_S3_ENDPOINT=                        # blank = AWS; e.g. https://minio.example.com or https://<account>.r2.cloudflarestorage.com
# REGISTRY_S3_ROOT_DIRECTORY=                  # optional key prefix inside the bucket
# REGISTRY_S3_SECURE=true                      # set false for HTTP-only MinIO or non-TLS S3-compatible endpoints
# REGISTRY_S3_FORCE_PATH_STYLE=false           # set true for MinIO, Cloudflare R2, or any custom endpoint (required by Distribution v3)
# REGISTRY_S3_REDIRECT_ENDPOINT=               # public URL for presigned download redirects — set if your S3 endpoint is internal-only

# Set to 1 only when running behind an HTTPS reverse proxy (Nginx/Caddy/Traefik)
SECURE_SSL_REDIRECT=0

# Cookie security — set to 1 in production (HTTPS).
# SESSION_COOKIE_SECURE=0
# CSRF_COOKIE_SECURE=0

# Timezone for Django and Celery Beat (default: UTC).
# Use any tz database name, e.g. America/New_York, Europe/London, Asia/Tokyo.
TIME_ZONE=UTC
